# =============================================================================
# DNR Auto-Submit Backend - Variables d'environnement
# =============================================================================
# Copier ce fichier en .env et remplir les valeurs.
# Sur Render : configurer ces variables dans le dashboard du service.
# =============================================================================

# --- SMTP (Gmail exemple, voir README pour Outlook/SendGrid) -----------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton.adresse@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
# ^ Pour Gmail : générer un "Mot de passe d'application" sur
#   https://myaccount.google.com/apppasswords (2FA obligatoire)

# --- Adresses ---------------------------------------------------------------
# FROM_EMAIL : ce qui apparaîtra côté Amazon comme expéditeur.
# Si non précisé, utilise SMTP_USER.
# IMPORTANT : Amazon identifie probablement la station via l'expéditeur.
# Utilise donc l'adresse pro que tu utilisais avant manuellement.
FROM_EMAIL=ton.adresse@gmail.com

# Destinataire Amazon - normalement pas à toucher
TO_EMAIL=dnr-investigations@eulmdxdasboard.amzl.amazon.dev

# --- Auth Tampermonkey -> Backend -------------------------------------------
# Générer une chaîne aléatoire forte, ex: `openssl rand -hex 32`
# Doit matcher la clé renseignée dans le menu Tampermonkey.
API_KEY=remplace_moi_par_un_secret_long_et_aleatoire

# --- Optionnel --------------------------------------------------------------
LOG_TO_FILE=1
